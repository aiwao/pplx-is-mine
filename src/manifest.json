{
  "manifest_version": 3,
  "name": "Perplexity is mine",
  "version": "1.0.0",

  "description": "Perplexity request patcher, for change the model, for skip the search, etc...",
  
  "browser_specific_settings": {
    "gecko": {
      "id": "pplx-is-mine@140.lol"
    }
  },

  "icons": {
    "19": "./assets/icon19.png",
    "38": "./assets/icon38.png",
    "48": "./assets/icon48.png",
    "96": "./assets/icon96.png",
    "128": "./assets/icon128.png",
    "256": "./assets/icon256.png",
    "512": "./assets/icon512.png"
  },

  "permissions": [ "storage" ],
  "host_permissions": [ "https://*.perplexity.ai/*" ],
  
  "action": {
    "default_title": "Options"
  },

  "options_ui": {
    "page": "./options_ui/options.html"
  },

  "background": {
    "scripts": [ "./background.js" ]
  },

  "content_scripts": [
    {
      "js": [ "./content.js" ],
      "matches": [ "https://*.perplexity.ai/*" ],
      "run_at": "document_start",
      "world": "ISOLATED"
    },
    {
      "js": [ "./patcher.js" ],
      "matches": [ "https://*.perplexity.ai/*" ],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ]
}
